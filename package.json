{
	"name": "github-action-homebrew-bump-cask",
	"version": "3.8.8",
	"private": true,
	"description": "A GitHub Action to easily bump Homebrew cask on new release.",
	"keywords": [
		"github-action",
		"action",
		"cask",
		"homebrew"
	],
	"homepage": "https://github.com/kitschpatrol/github-action-homebrew-bump-cask",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/github-action-homebrew-bump-cask.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Macauley"
	},
	"contributors": [
		{
			"name": "Dawid Dziurla"
		},
		{
			"name": "Eric Mika",
			"email": "eric@ericmika.com",
			"url": "https://ericmika.com"
		}
	],
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc-prettier fix",
		"lint": "ksc-prettier lint",
		"updatetag": "git tag -d v3 && git push origin :v3 && git tag -a v3 -m '' && git push origin v3"
	},
	"devDependencies": {
		"@kitschpatrol/prettier-config": "^6.1.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.0.0"
	}
}
